# Copy to .env and fill in real values. Keep .env out of git.

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15555550123

# --- Public base URL (ngrok tunnel, e.g. https://abcd1234.ngrok.app) ---
# Must be HTTPS and publicly reachable by Twilio for webhooks.
BASE_URL=https://your-ngrok-subdomain.ngrok.app

# --- The single pre-approved recipient. E.164 format only. ---
# This is the ONLY number this app will ever dial.
APPROVED_TO_NUMBER=+15555550199

# --- Optional ElevenLabs TTS for generating prank audio ---
# If unset, the audio generation feature is disabled and you can paste a hosted MP3 URL instead.
ELEVENLABS_API_KEY=
# Optional voice id; defaults to a generic one if unset.
ELEVENLABS_VOICE_ID=

# --- Optional default MP3 URL to pre-fill the audio field ---
DEFAULT_MP3_URL=

# --- Server port (defaults to 3000) ---
PORT=3000
