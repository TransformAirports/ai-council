outputs/
.DS_Store
.env

# Python CLI build / venv artifacts
.venv*/
__pycache__/
*.egg-info/
build/
dist/

# Allow archived deliverables in completed runs — each run folder is a curated
# reference artifact that includes its finished Word documents.
!runs/**/*.docx
!runs/**/*.pdf

# Polished, distribution-ready reports are regenerable from the archives via
# `council --publish`. Treated as build output, not committed.
reports/

# Operator-local config (edited via Settings in ./council) and error logs.
council.toml
logs/
